---
import Navbar from '../components/global/Navbar.astro';
import Footer from '../components/global/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'Pendar Sinergi Utama | Enterprise Digital Architects', 
  description = 'High-performance digital ecosystems, enterprise architecture, and technical consulting built to accelerate digital transformation.' 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Primary SEO Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&display=swap" rel="stylesheet" fetchpriority="high" />

    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <Navbar />
    
    <main id="main-content">
      <slot />
    </main>

    <Footer />

    <!-- Floating WhatsApp Button (Mobile Only) -->
    <a href="https://wa.me/6282110962949?text=Hello%20Pendar%20Team%2C%20I%27m%20interested%20in%20learning%20more%20about%20your%20solutions%20and%20discussing%20our%20organization%27s%20requirements.%20Could%20we%20schedule%20a%20brief%20discussion%3F" class="whatsapp-fab" target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp">
      <svg
        class="whatsapp-fab-icon"
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="12" y1="19" x2="12" y2="5"></line>
        <polyline points="5 12 12 5 19 12"></polyline>
      </svg>
    </a>
  </body>
</html>
