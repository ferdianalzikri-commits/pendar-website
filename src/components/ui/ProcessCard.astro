---
interface Props {
  stepNumber: string;
  title: string;
  description: string;
  deliverables: string[];
}

const { stepNumber, title, description, deliverables } = Astro.props;
---

<div class="process-card">
  <div class="process-header">
    <span class="process-number">{stepNumber}</span>
    <h3 class="process-title">{title}</h3>
  </div>
  
  <p class="process-description">{description}</p>
  
  {deliverables && deliverables.length > 0 && (
    <div class="process-deliverables">
      <h4 class="deliverables-heading">Key Output:</h4>
      <ul class="deliverables-list">
        {deliverables.map((deliverable) => (
          <li>
            <span class="bullet" aria-hidden="true">✓</span>
            <span>{deliverable}</span>
          </li>
        ))}
      </ul>
    </div>
  )}
</div>

<style>
  .process-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    position: relative;
    transition: var(--transition-all);
  }

  .process-card:hover {
    border-color: var(--color-primary);
  }

  .process-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .process-number {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-primary);
    background-color: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .process-title {
    font-size: var(--text-md);
    color: var(--color-text);
  }

  .process-description {
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  .process-deliverables {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-4);
    margin-top: auto;
  }

  .deliverables-heading {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .deliverables-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-size: var(--text-xs);
  }

  .deliverables-list li {
    display: flex;
    gap: var(--space-2);
    align-items: center;
    color: var(--color-text-muted);
  }

  .bullet {
    color: var(--color-primary);
    font-weight: bold;
  }
</style>
