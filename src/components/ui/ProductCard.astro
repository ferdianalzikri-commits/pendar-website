---
import Button from '../global/Button.astro';

interface Props {
  name: string;
  tagline: string;
  description: string;
  features: string[];
  techStack: string[];
  stats: { label: string; value: string };
  actionText: string;
}

const { name, tagline, description, features, techStack, stats, actionText } = Astro.props;
---

<article class="product-card">
  <div class="product-header">
    <div class="product-meta">
      <h3 class="product-name">{name}</h3>
      <p class="product-tagline">{tagline}</p>
    </div>
    {stats && (
      <div class="product-stat">
        <span class="stat-value">{stats.value}</span>
        <span class="stat-label">{stats.label}</span>
      </div>
    )}
  </div>

  <p class="product-description">{description}</p>

  <div class="product-details">
    <div class="details-section">
      <h4 class="details-title">Key Capabilities</h4>
      <ul class="features-list">
        {features.map((feature) => (
          <li>
            <span class="bullet" aria-hidden="true">→</span>
            <span>{feature}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="details-section">
      <h4 class="details-title">Technology Stack</h4>
      <div class="tech-tags">
        {techStack.map((tech) => (
          <span class="tech-badge">{tech}</span>
        ))}
      </div>
    </div>
  </div>

  <div class="product-actions">
    <Button href="#contact" variant="primary">{actionText}</Button>
  </div>
</article>

<style>
  .product-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    transition: var(--transition-all);
    position: relative;
    overflow: hidden;
  }

  .product-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
    opacity: 0;
    transition: var(--transition-all);
  }

  .product-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.4);
  }

  .product-card:hover::before {
    opacity: 1;
  }

  .product-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .product-name {
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .product-tagline {
    font-size: var(--text-sm);
    color: var(--color-primary);
    font-weight: 500;
  }

  .product-stat {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
  }

  .stat-value {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
  }

  .stat-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .product-description {
    font-size: var(--text-md);
    line-height: 1.5;
  }

  .product-details {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-4) 0;
  }

  @media (min-width: 640px) {
    .product-details {
      grid-template-columns: 1.2fr 0.8fr;
      gap: var(--space-6);
    }
  }

  .details-title {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .features-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: var(--text-sm);
  }

  .features-list li {
    display: flex;
    gap: var(--space-2);
    align-items: flex-start;
    color: var(--color-text-muted);
  }

  .bullet {
    color: var(--color-primary);
    font-weight: bold;
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tech-badge {
    background-color: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text);
  }

  .product-actions {
    margin-top: auto;
  }
</style>
