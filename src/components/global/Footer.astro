---
import pendarLogoLong from "../../images/Pendar-long.svg";
---

<footer class="footer-block">
  <div class="container footer-container">
    <!-- Left Column: Brand, Address, Phone -->
    <div class="footer-left">
      <div class="footer-brand">
        <a
          href="#hero"
          class="brand-logo"
          aria-label="Pendar Sinergi Utama Home"
        >
          <img
            src={pendarLogoLong.src}
            alt="Pendar Sinergi Utama"
            class="brand-logo-img"
            width={pendarLogoLong.width}
            height={pendarLogoLong.height}
            loading="lazy"
            decoding="async"
          />
        </a>
      </div>

      <div class="footer-address">
        <span class="address-title">Office 88 Casablanca Tower A</span>
        <span class="address-line"
          >Jalan Casablanca No.16, Lantai 9, Menteng Dalam,</span
        >
        <span class="address-line">Tebet - Jakarta Selatan</span>
      </div>

      <div class="footer-phone">
        <span class="phone-label">P.</span> +62 21 2854 1720
      </div>
    </div>

    <!-- Right Column: Site Map & Resources -->
    <div class="footer-right">
      <div class="footer-group">
        <span class="footer-group-label">Site Map</span>
        <ul class="footer-group-links">
          <li><a href="#hero">Home</a></li>
          <li><a href="#industries">About Us</a></li>
          <li><a href="#values">Values</a></li>
          <li><a href="#products">Products</a></li>
        </ul>
      </div>

      <div class="footer-group">
        <span class="footer-group-label">Resources</span>
        <ul class="footer-group-links">
          <li><a href="/terms-of-use">Term of use</a></li>
          <li><a href="/privacy-policy">Privacy Policy</a></li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Copyright Section -->
  <div class="container footer-bottom">
    <p class="copyright">
      &copy; 2026 PT Pendar Sinergi Utama. All rights reserved.
    </p>
  </div>
</footer>

<style>
  .footer-block {
    background-color: var(--color-white);
    padding-top: 80px;
    padding-bottom: 40px;
  }

  .footer-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  /* Left Column */
  .footer-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-8);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2);
  }

  .brand-logo-img {
    height: 64px;
    width: auto;
    display: block;
  }

  .footer-address {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    font-size: var(--text-base);
    line-height: 1.5;
    color: var(--color-blue);
  }

  .address-title {
    font-weight: 700;
    color: var(--color-blue);
    margin-bottom: var(--space-1);
  }

  .address-line {
    font-weight: 400;
    color: var(--color-blue);
    opacity: 0.95;
  }

  .footer-phone {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-blue);
  }

  .phone-label {
    color: var(--color-med-blue);
    font-weight: 500;
    margin-right: var(--space-1);
  }

  /* Right Column */
  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-10);
  }

  .footer-group {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
    width: 100%;
  }

  .footer-group-label {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-med-blue);
  }

  .footer-group-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: var(--space-8); /* 32px gap between horizontal links */
  }

  .footer-group-links a {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-blue);
    transition: var(--transition-all);
  }

  .footer-group-links a:hover {
    color: var(--color-orange);
  }

  /* Bottom Copyright Section */
  .footer-bottom {
    margin-top: 64px;
    padding-top: var(--space-8);
    text-align: left;
  }

  .copyright {
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--color-med-blue) !important;
    margin: 0;
  }

  /* Responsive / Desktop Breakpoint */
  @media (min-width: 1024px) {
    .footer-block {
      padding-top: 120px;
      padding-bottom: 60px;
    }

    .footer-container {
      grid-template-columns: 1.1fr 0.9fr; /* Two-column layout */
      gap: var(--space-16);
    }

    .footer-right {
      align-items: flex-start;
      justify-self: end;
      padding-left: 0;
    }

    .footer-bottom {
      margin-top: 80px;
    }
  }
</style>
