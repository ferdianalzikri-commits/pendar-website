---
import bulletPoint from "../../images/bullet-point.png";
import icArrow from "../../images/ic-arrow.svg";
import ring1 from "../../images/Ring1.png";
---

<section class="hero" id="hero">
  <div class="container hero-container">
    <!-- Column A: 60% Width -->
    <div class="hero-left">
      <div class="hero-expertise">
        <span class="expertise-text">Expertise Across</span>
        <span class="expertise-badge"
          ><span class="badge-text">Procurement Operations</span><span
            class="badge-cursor">|</span
          ></span
        >
      </div>

      <h1 class="hero-title">
        <span class="hero-title-mask"
          ><span class="hero-title-line">Turning Complex</span></span
        >
        <span class="hero-title-mask"
          ><span class="hero-title-line">Challenges Into</span></span
        >
        <span class="hero-title-mask"
          ><span class="hero-title-line">Digital Solutions</span></span
        >
      </h1>

      <ul class="hero-points">
        <li class="point-item">
          <img src={bulletPoint.src} alt="" class="point-icon" width={bulletPoint.width} height={bulletPoint.height} />
          <span class="point-text">Reduce Complexity</span>
        </li>
        <li class="point-divider" aria-hidden="true">|</li>
        <li class="point-item">
          <img src={bulletPoint.src} alt="" class="point-icon" width={bulletPoint.width} height={bulletPoint.height} />
          <span class="point-text">Enable Collaboration</span>
        </li>
        <li class="point-divider" aria-hidden="true">|</li>
        <li class="point-item">
          <img src={bulletPoint.src} alt="" class="point-icon" width={bulletPoint.width} height={bulletPoint.height} />
          <span class="point-text">Increase Ops Visibility</span>
        </li>
      </ul>

      <div class="hero-actions">
        <a href="#products" class="btn-primary-custom">Explore Our Solution</a>
        <div class="scroll-discover">
          <a
            href="#industries"
            class="btn-circle-outline"
            aria-label="Scroll to Discover"
          >
            <img src={icArrow.src} alt="" class="arrow-icon" width={icArrow.width} height={icArrow.height} />
          </a>
          <span class="scroll-text">Scroll to Discover</span>
        </div>
      </div>
    </div>

    <!-- Column B: 40% Width -->
    <div class="hero-right">
      <img src={ring1.src} alt="" class="hero-ring-image" width={ring1.width} height={ring1.height} fetchpriority="high" loading="eager" decoding="sync" />
    </div>
  </div>
</section>

<style>
  .hero-title-mask {
    display: inline-block;
    vertical-align: bottom;
    overflow: hidden;
    padding-bottom: 0.15em;
    margin-bottom: -0.15em;
  }

  .hero-title-line {
    display: inline-block;
  }

  @media (min-width: 1024px) {
    .hero-title-mask {
      display: block;
    }
    .hero-title-line {
      display: block;
    }
  }

  /* Keyframe Animations */
  @keyframes reveal-text {
    from {
      transform: translateY(100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(25px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes blow-balloon-enter {
    0% {
      opacity: 0;
      scale: 0;
    }
    100% {
      opacity: 1;
      scale: 1;
    }
  }

  @keyframes rotate-endless {
    from {
      rotate: 0deg;
    }
    to {
      rotate: 360deg;
    }
  }

  .hero-expertise {
    opacity: 0;
    animation: fade-in-up 1.8s cubic-bezier(0.05, 1, 0.1, 1) forwards;
  }

  .hero-title-line {
    opacity: 0;
    transform: translateY(100%);
    animation: reveal-text 1.8s cubic-bezier(0.05, 1, 0.1, 1) 0.35s forwards;
  }

  .hero-title-mask:nth-child(2) .hero-title-line {
    animation-delay: 0.65s;
  }

  .hero-title-mask:nth-child(3) .hero-title-line {
    animation-delay: 0.95s;
  }

  .hero-points {
    opacity: 0;
    animation: fade-in-up 1.8s cubic-bezier(0.05, 1, 0.1, 1) 1.2s forwards;
  }

  .hero-actions > * {
    opacity: 0;
    animation: fade-in-up 1.8s cubic-bezier(0.05, 1, 0.1, 1) forwards;
  }

  .hero-actions > *:nth-child(1) {
    animation-delay: 1.45s;
  }

  .hero-actions > *:nth-child(2) {
    animation-delay: 1.6s;
  }

  /* Reset layout/opacity if user prefers reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-expertise,
    .hero-points,
    .hero-actions > *,
    .hero-ring-image {
      opacity: 1;
      transform: none;
      animation: none;
    }
    .hero-title-line {
      transform: none;
      animation: none;
    }
  }

  .expertise-badge {
    display: inline-flex;
    align-items: center;
    box-sizing: border-box;
    white-space: nowrap;
  }

  .badge-cursor {
    display: inline-block;
    color: var(--color-white);
    margin-left: 2px;
    font-weight: 300;
    animation: cursor-blink 0.8s steps(2, start) infinite;
  }

  @keyframes cursor-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .hero {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: var(--color-white);
  }

  .hero-container {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-32);
    align-items: center;
    padding-top: 80px;
    padding-bottom: clamp(60px, 5.56vw, 80px);
    min-height: calc(100vh - 112px);
    position: relative;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    z-index: var(--z-above);
  }

  /* Above the headline */
  .hero-expertise {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: var(--text-md);
    font-weight: 500;
    color: var(--color-blue);
    margin-bottom: 32px; /* Space (32px) */
  }

  /* Headline */
  .hero-title {
    font-size: var(--text-4xl);
    font-weight: 600;
    line-height: 1.15;
    color: var(--color-navy);
    margin-bottom: 64px; /* Space (64px) */
    max-width: 100%;
    letter-spacing: -0.02em;
  }

  /* 3 Horizontal Points */
  .hero-points {
    display: flex;
    align-items: center;
    list-style: none;
    padding: 0;
    margin: 0;
    height: 64px; /* h:64px */
    margin-bottom: 64px; /* Space (64px) */
  }

  .point-item {
    display: inline-flex;
    align-items: center;
    gap: 16px; /* gap 16px between bullet and text */
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-navy);
  }

  .point-icon {
    height: 24px;
    width: auto;
  }

  .point-divider {
    margin-inline: 16px; /* gap between separation line 16px */
    color: var(--color-blue);
    font-weight: 200;
    font-size: var(--text-base);
  }

  /* Buttons */
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 24px; /* Space 24px between components */
  }

  .scroll-discover {
    display: flex;
    align-items: center;
    gap: 16px; /* 16px space from the button */
  }

  .arrow-icon {
    width: 20px;
    height: 20px;
    animation: arrow-jump 2s infinite;
  }

  @keyframes arrow-jump {
    0%, 20%, 50%, 80%, 100% {
      transform: translateY(0);
    }
    40% {
      transform: translateY(6px);
    }
    60% {
      transform: translateY(3px);
    }
  }

  .scroll-text {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-navy);
  }

  /* Column B: Right Ring Image */
  .hero-right {
    position: relative;
    width: 25vw;
    max-width: 350px;
    min-width: 225px;
    height: 100%;
    margin-right: calc(-1 * max(20px, 4.44vw));
    display: flex;
    align-items: center;
    overflow: visible;
  }

  .hero-ring-image {
    position: absolute;
    right: 0;
    translate: 50% 0;
    width: 50vw;
    max-width: 700px;
    min-width: 450px;
    height: auto;
    pointer-events: none;
    z-index: var(--z-base);
    opacity: 0;
    transform-origin: center center;
    animation: 
      blow-balloon-enter 1.2s cubic-bezier(0.05, 1, 0.1, 1) 0.45s forwards,
      rotate-endless 45s linear 0.45s infinite;
  }

  /* Responsive styling */
  @media (max-width: 1024px) {
    .hero-container {
      grid-template-columns: 1fr;
      gap: 48px;
      padding-top: 100px;
      text-align: center;
    }

    .hero-left {
      align-items: center;
    }

    .hero-expertise {
      flex-direction: column;
      font-size: var(--text-base);
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 24px;
    }

    .hero-title {
      font-size: 2.5rem;
      margin-bottom: 32px;
      max-width: 100%;
    }

    .hero-points {
      flex-direction: column;
      height: auto;
      gap: 16px;
      margin-bottom: 48px;
    }

    .point-divider {
      display: none;
    }

    .hero-actions {
      flex-direction: column;
      gap: 20px;
      width: 100%;
    }

    .btn-primary-custom {
      scale: 80%;
      max-width: 280px;
    }

    .scroll-discover {
      justify-content: center;
    }

    .hero-right {
      display: none;
    }

    .hero-ring-image {
      display: none;
    }
  }

  /* Very small mobile screens */
  @media (max-width: 400px) {
    .hero-container {
      padding-top: 80px;
    }

    .hero-expertise {
      font-size: var(--text-xs);
      margin-bottom: 16px;
    }

    .hero-title {
      font-size: 1.75rem;
      margin-bottom: 24px;
    }

    .hero-points {
      gap: 12px;
      margin-bottom: 32px;
    }

    .point-item {
      font-size: var(--text-xs);
      gap: 10px;
    }

    .point-icon {
      height: 18px;
    }

    .hero-actions {
      gap: 16px;
    }

    .scroll-text {
      font-size: var(--text-xs);
    }
  }

  /* Extra large screens */
  @media (min-width: 1600px) {
    .hero-ring-image {
      width: 57.5vw;
      max-width: 805px;
    }
  }
</style>

<script is:inline>
  let typewriterInitialized = false;

  function initHeroTypewriter() {
    if (typewriterInitialized) return;

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (prefersReducedMotion) return;

    const badgeText = document.querySelector(".expertise-badge .badge-text");
    if (!badgeText) return;

    typewriterInitialized = true;

    const phrases = [
      "Procurement Operations.",
      "Workforce Management.",
      "Logistics Coordination.",
      "Aviation Operations.",
      "Port Management.",
      "Organizational Workflows.",
    ];

    let phraseIndex = 0;
    let charIndex = phrases[0].length;
    let isDeleting = false;
    let timeoutId = null;
    let isPageVisible = true;

    function type() {
      if (!isPageVisible) return;

      const currentPhrase = phrases[phraseIndex];
      let delay = 100;

      if (isDeleting) {
        badgeText.textContent = currentPhrase.substring(0, charIndex);
        charIndex--;
        delay = 15; // fast deleting speed
      } else {
        badgeText.textContent = currentPhrase.substring(0, charIndex);
        charIndex++;
        delay = 40; // fast typing speed
      }

      if (!isDeleting && charIndex > currentPhrase.length) {
        isDeleting = true;
        delay = 1200; // Pause briefly when completed
      } else if (isDeleting && charIndex < 0) {
        isDeleting = false;
        phraseIndex = (phraseIndex + 1) % phrases.length;
        charIndex = 0;
        delay = 300; // brief pause before typing next
      }

      timeoutId = setTimeout(type, delay);
    }

    function handleVisibilityChange() {
      if (document.hidden) {
        isPageVisible = false;
        if (timeoutId) {
          clearTimeout(timeoutId);
          timeoutId = null;
        }
      } else {
        isPageVisible = true;
        if (!timeoutId) {
          timeoutId = setTimeout(type, 100);
        }
      }
    }

    document.addEventListener("visibilitychange", handleVisibilityChange);

    // Initial start after opening
    timeoutId = setTimeout(type, 3000);
  }

  document.addEventListener("DOMContentLoaded", initHeroTypewriter);
  if (
    document.readyState === "complete" ||
    document.readyState === "interactive"
  ) {
    initHeroTypewriter();
  }
</script>
