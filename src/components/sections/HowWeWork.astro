---
import { Image } from "astro:assets";
import gradientBg from "../../images/gradient.png";

// Process steps dataset based on approved 6-step work cycle (rebuild trigger)
const processSteps = [
  {
    stepNumber: "01",
    title: "Business & Workflow Analysis",
    tag: "discovery",
    description:
      "We assess operational workflows and business requirements before defining solution strategies.",
  },
  {
    stepNumber: "02",
    title: "UI/UX & Operational Experience Design",
    tag: "design",
    description:
      "User interfaces and system experiences are designed to support usability, operational efficiency, and intuitive workflow interaction across enterprise environments.",
  },
  {
    stepNumber: "03",
    title: "Custom Enterprise Development",
    tag: "build",
    description:
      "Systems are developed based on organizational workflows, operational scalability, and integration requirements.",
  },
  {
    stepNumber: "04",
    title: "Testing & Change Request Management",
    tag: "validation",
    description:
      "Structured testing and controlled change management ensure solution stability throughout implementation.",
  },
  {
    stepNumber: "05",
    title: "Deployment & User Enablement",
    tag: "go-live",
    description:
      "Deployment, documentation, and user training are prepared to support smooth operational adoption.",
  },
  {
    stepNumber: "06",
    title: "Continuous Support & Enhancement",
    tag: "post-launch",
    description:
      "We provide long-term maintenance, monitoring, and enhancement services after deployment.",
  },
];
---

<section class="how-we-work section-padding" id="process">
  <!-- Decorative Background Oval Shape -->
  <div class="how-we-work__bg-shape"></div>
  <Image 
    src={gradientBg} 
    alt="" 
    class="how-we-work__gradient-bg" 
    aria-hidden="true" 
  />

  <div class="container how-we-work__container">
    <div class="how-we-work__inner">
      <!-- Column A (40%) -->
      <div class="how-we-work__col-a">
        <span class="label-pill">How We Work</span>
        <h2 class="how-we-work__headline">
          <span class="headline-mask"
            ><span class="headline-line">From Discovery</span></span
          >
          <span class="headline-mask"
            ><span class="headline-line">to Long-Term Support</span></span
          >
        </h2>
        <p class="how-we-work__description">
          We support enterprise projects through every stage—from understanding
          business workflows and designing solutions to development, deployment,
          and long-term support. Ensuring each system delivers lasting
          operational value.
        </p>
      </div>

      <!-- Column B -->
      <div class="how-we-work__col-b">
        <div class="how-we-work__steps">
          <!-- Cards List -->
          <div class="how-we-work__cards">
            {
              processSteps.map((step, index) => {
                return (
                  <div
                    class="process-card liquid-glass"
                    style={`--card-index: ${index + 1};`}
                  >
                    <div class="process-card__icon-container">
                      {step.tag === "discovery" && (
                        <svg
                          class="process-card__icon"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <circle cx="11" cy="11" r="8" />
                          <line x1="21" y1="21" x2="16.65" y2="16.65" />
                        </svg>
                      )}
                      {step.tag === "design" && (
                        <svg
                          class="process-card__icon"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                          <line x1="3" y1="9" x2="21" y2="9" />
                          <line x1="9" y1="21" x2="9" y2="9" />
                        </svg>
                      )}
                      {step.tag === "build" && (
                        <svg
                          class="process-card__icon"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <polyline points="16 18 22 12 16 6" />
                          <polyline points="8 6 2 12 8 18" />
                        </svg>
                      )}
                      {step.tag === "validation" && (
                        <svg
                          class="process-card__icon"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <polyline points="9 11 12 14 22 4" />
                          <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
                        </svg>
                      )}
                      {step.tag === "go-live" && (
                        <svg
                          class="process-card__icon"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <path d="M12 2s-4 3.5-4 8.5c0 4.5 4 6.5 4 6.5s4-2 4-6.5C16 5.5 12 2 12 2z" />
                          <path d="M8 12.5l-3 2v3.5h3v-2" />
                          <path d="M16 12.5l3 2v3.5h-3v-2" />
                          <circle cx="12" cy="9" r="1.5" />
                          <path d="M12 17v3" />
                        </svg>
                      )}
                      {step.tag === "post-launch" && (
                        <svg
                          class="process-card__icon"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <circle cx="12" cy="12" r="10" />
                          <circle cx="12" cy="12" r="4" />
                          <line x1="4.93" y1="4.93" x2="9.17" y2="9.17" />
                          <line x1="14.83" y1="14.83" x2="19.07" y2="19.07" />
                          <line x1="14.83" y1="9.17" x2="19.07" y2="4.93" />
                          <line x1="4.93" y1="19.07" x2="9.17" y2="14.83" />
                        </svg>
                      )}
                    </div>
                    <div class="process-card__body">
                      <h3 class="process-card__title">
                        {step.tag && (
                          <span class="process-card__tag">
                            &lt;{step.tag}&gt;&nbsp;
                          </span>
                        )}
                        {step.title}
                      </h3>
                      <p class="process-card__desc">{step.description}</p>
                    </div>
                  </div>
                );
              })
            }
          </div>

          <!-- Timeline Track Widget (Desktop Only) -->
          <div class="how-we-work__timeline">
            <div
              class="how-we-work__timeline-line how-we-work__timeline-line--top"
              style="margin-left: 32px;"
            >
            </div>
            <div class="how-we-work__timeline-curve-container">
              <svg
                class="how-we-work__timeline-curve"
                width="80"
                height="120"
                viewBox="0 0 80 120"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M 33,0 L 33,10 C 33,35 13,45 13,60 C 13,75 33,85 33,110 L 33,120"
                  stroke="var(--color-orange)"
                  stroke-width="2"
                  stroke-linecap="round"
                  fill="none"></path>
                <circle cx="33" cy="60" r="12" fill="var(--color-orange)"
                ></circle>
              </svg>
              <span class="how-we-work__timeline-number"></span>
            </div>
            <div
              class="how-we-work__timeline-line how-we-work__timeline-line--bottom"
              style="margin-left: 32px;"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .how-we-work {
    margin-top: var(--space-40);
    padding-top: var(--space-24) !important;
    padding-bottom: var(--space-48) !important;
    position: relative;
    overflow: visible; /* But parent wrapper clips it */
  }

  .how-we-work__gradient-bg {
    position: absolute;
    top: 50%;
    right: 0;
    transform: translateY(-50%);
    z-index: 0;
    pointer-events: none;
    max-height: 100%;
    object-fit: contain;
  }

  .how-we-work__container {
    position: relative;
    z-index: 1;
  }

  .how-we-work__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-32);
    width: 100%;
  }

  /* Column A Info Panel */
  .how-we-work__col-a {
    display: column;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
    max-width: 100%;
    min-width: 0;
  }

  /* Specificity boost for global dark-sections-wrapper label overrides */
  section.how-we-work .label-pill {
    color: var(--color-blue) !important;
    background-color: var(--color-shade-blue) !important;
    margin-bottom: var(--space-5);
  }

  .how-we-work__headline {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-white) !important;
    line-height: 1.15;
    margin: 0;
    margin-bottom: var(--space-10);
    text-align: center;
  }

  section.how-we-work p.how-we-work__description {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-light-blue) !important;
    line-height: 1.6;
    margin: 0;
  }

  /* Column B Grid & Cards */
  .how-we-work__col-b {
    width: 100%;
    min-width: 0;
  }

  .how-we-work__steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-32);
    width: 100%;
    min-width: 0;
  }

  .how-we-work__cards {
    position: relative;
    display: block;
    min-height: 548px; /* 3 cards * 140px + 2 gaps * 64px */
    flex: 1;
    min-width: 0;
  }

  /* Premium Glass Cards (CoreValues layout wrapper) */
  .process-card {
    position: absolute;
    top: 50%;
    left: 50%;
    overflow: visible;
    border-radius: 24px;
    padding: 24px;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-6);
    width: 100%;
    max-width: 720px;
    min-width: 0;
    will-change: transform, opacity;
    animation-name: carousel-animate-vertical;
    animation-duration: 18s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-delay: calc((var(--card-index) * 3s) - 21s);
  }

  @keyframes carousel-animate-vertical {
    0% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 1;
      visibility: visible;
      z-index: 2;
      background-color: var(--color-orange);
      border-color: var(--color-orange);
      animation-timing-function: linear;
    }
    11.111% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 1;
      visibility: visible;
      z-index: 2;
      background-color: var(--color-orange);
      border-color: var(--color-orange);
      animation-timing-function: ease-in-out;
    }
    16.666% {
      /* Prev: exits to BOTTOM */
      transform: translate(-50%, calc(-50% + 100% + var(--space-16))) scale(0.8);
      opacity: 1;
      visibility: visible;
      z-index: 1;
      background-color: transparent;
      border-color: rgba(255, 255, 255, 0.08);
      animation-timing-function: linear;
    }
    27.777% {
      transform: translate(-50%, calc(-50% + 100% + var(--space-16))) scale(0.8);
      opacity: 1;
      visibility: visible;
      z-index: 1;
      background-color: transparent;
      border-color: rgba(255, 255, 255, 0.08);
      animation-timing-function: ease-in-out;
    }
    33.333% {
      /* Hidden Bottom */
      transform: translate(-50%, calc(-50% + 100% + var(--space-16))) scale(0.8);
      opacity: 0;
      visibility: hidden;
      z-index: 0;
      background-color: transparent;
      border-color: rgba(255, 255, 255, 0.08);
      animation-timing-function: linear;
    }
    83.332% {
      /* Hold hidden state */
      transform: translate(-50%, calc(-50% + 100% + var(--space-16))) scale(0.8);
      opacity: 0;
      visibility: hidden;
      z-index: 0;
      background-color: transparent;
      border-color: rgba(255, 255, 255, 0.08);
      animation-timing-function: step-end;
    }
    83.333% {
      /* Snap to Top, start scale 0 */
      transform: translate(-50%, calc(-50% - 100% - var(--space-16))) scale(0);
      opacity: 1; /* Instant opacity, no fade in */
      visibility: visible;
      z-index: 1;
      background-color: transparent;
      border-color: rgba(255, 255, 255, 0.08);
      animation-timing-function: ease-out;
    }
    86.111% {
      /* Balloon overshoot */
      transform: translate(-50%, calc(-50% - 100% - var(--space-16)))
        scale(0.85);
      opacity: 1;
      visibility: visible;
      z-index: 1;
      background-color: transparent;
      border-color: rgba(255, 255, 255, 0.08);
      animation-timing-function: ease-in-out;
    }
    88.888% {
      /* Settle at Top */
      transform: translate(-50%, calc(-50% - 100% - var(--space-16))) scale(0.8);
      opacity: 1;
      visibility: visible;
      z-index: 1;
      background-color: transparent;
      border-color: rgba(255, 255, 255, 0.08);
      animation-timing-function: linear;
    }
    94.444% {
      /* Next: begins entering from TOP */
      transform: translate(-50%, calc(-50% - 100% - var(--space-16))) scale(0.8);
      opacity: 1;
      visibility: visible;
      z-index: 1;
      background-color: transparent;
      border-color: rgba(255, 255, 255, 0.08);
      animation-timing-function: ease-in-out;
    }
    100% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 1;
      visibility: visible;
      z-index: 2;
      background-color: var(--color-orange);
      border-color: var(--color-orange);
    }
  }

  .process-card__tag {
    animation-name: tag-color-animate;
    animation-duration: 18s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-delay: calc((var(--card-index) * 3s) - 21s);
  }

  @keyframes tag-color-animate {
    0% {
      color: var(--color-blue);
      animation-timing-function: linear;
    }
    11.111% {
      color: var(--color-blue);
      animation-timing-function: ease-in-out;
    }
    16.666% {
      color: var(--color-orange);
      animation-timing-function: linear;
    }
    94.444% {
      color: var(--color-orange);
      animation-timing-function: ease-in-out;
    }
    100% {
      color: var(--color-blue);
    }
  }

  @keyframes desc-color-animate {
    0% {
      color: var(--color-white);
      animation-timing-function: linear;
    }
    11.111% {
      color: var(--color-white);
      animation-timing-function: ease-in-out;
    }
    16.666% {
      color: var(--color-light-blue);
      animation-timing-function: linear;
    }
    94.444% {
      color: var(--color-light-blue);
      animation-timing-function: ease-in-out;
    }
    100% {
      color: var(--color-white);
    }
  }

  /* Icon Container (matches CoreValues placeholder styling) */
  .process-card__icon-container {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.08) 0%,
      rgba(255, 255, 255, 0.02) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-white);
    flex-shrink: 0;
  }

  .process-card__icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .process-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
    min-width: 0;
  }

  .process-card__title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-white) !important;
    margin: 0;
    line-height: 1.35;
  }

  section.how-we-work .process-card__tag {
    color: var(--color-orange);
    font-weight: 700;
  }

  section.how-we-work p.process-card__desc {
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--color-light-blue);
    margin: 0;
    line-height: 1.6;
    animation-name: desc-color-animate;
    animation-duration: 18s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    animation-delay: calc((var(--card-index) * 3s) - 21s);
  }

  /* Timeline widget hidden on mobile/tablet */
  .how-we-work__timeline {
    display: none;
  }

  /* Very small mobile screens */
  @media (max-width: 400px) {
    .how-we-work {
      margin-top: var(--space-24);
      padding-top: var(--space-16) !important;
      padding-bottom: var(--space-24) !important;
    }

    .how-we-work__inner {
      gap: var(--space-32);
    }

    .how-we-work__headline {
      font-size: 1.5rem;
      margin-bottom: var(--space-6);
    }

    .how-we-work__cards {
      min-height: 480px;
    }

    .process-card {
      padding: 16px;
      border-radius: 16px;
      gap: var(--space-4);
      max-width: 100%;
    }

    .process-card__icon-container {
      width: 48px;
      height: 48px;
      border-radius: 12px;
    }

    .process-card__icon {
      width: 20px;
      height: 20px;
    }

    .process-card__title {
      font-size: var(--text-xs);
    }

    section.how-we-work p.process-card__desc {
      font-size: 0.75rem;
    }
  }

  /* Desktop Responsive Styling */
  @media (min-width: 1024px) {
    .how-we-work__container {
      padding-inline: 64px;
    }

    .how-we-work__inner {
      display: grid;
      grid-template-columns: 1fr 720px;
      gap: var(--space-32);
      align-items: start;
      width: 100%;
    }

    @media (min-width: 1440px) {
      .how-we-work__inner {
        gap: var(--space-40);
      }
    }

    @media (min-width: 1600px) {
      .how-we-work__inner {
        gap: var(--space-48);
      }
    }

    @media (min-width: 1920px) {
      .how-we-work__inner {
        gap: var(--space-64);
      }
    }

    .how-we-work__col-a {
      align-items: flex-start;
      text-align: left;
      width: 100%;
      align-self: center;
    }

    .how-we-work__headline {
      font-size: var(--text-2xl);
      text-align: left;
    }

    section.how-we-work p.how-we-work__description {
      font-size: var(--text-md);
    }

    .how-we-work__steps {
      position: relative;
      width: 100%;
      max-width: 720px;
      padding-right: 160px;
    }

    /* Vertical Timeline track and curve */
    .how-we-work__timeline {
      display: block;
      width: 80px;
      position: absolute;
      right: 60px;
      top: 0;
      bottom: 0;
    }

    .how-we-work__timeline-line {
      width: 2px;
      margin-left: 32px; /* align center with the straight SVG line at x=33 */
    }

    .how-we-work__timeline-line--top {
      position: absolute;
      top: 0;
      bottom: calc(50% + 60px); /* Top edge down to timeline container peak */
      background: linear-gradient(
        to bottom,
        rgba(18, 40, 130, 0),
        var(--color-orange)
      );
    }

    .how-we-work__timeline-line--bottom {
      position: absolute;
      top: calc(50% + 60px); /* Bottom peak down to floor */
      bottom: 0;
      background: linear-gradient(
        to bottom,
        var(--color-orange),
        rgba(18, 40, 130, 0)
      );
    }

    .how-we-work__timeline-curve-container {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 80px;
      height: 120px;
      flex-shrink: 0;
    }

    .how-we-work__timeline-curve {
      width: 80px;
      height: 120px;
      display: block;
    }

    section.how-we-work .how-we-work__timeline-number {
      position: absolute;
      left: calc(45px + var(--space-6));
      top: 50%;
      transform: translateY(-50%);
      color: var(--color-orange) !important;
      font-size: var(--text-2xl);
      font-weight: 700;
      line-height: 1;
    }

    .how-we-work__timeline-number::before {
      content: "01";
      animation-name: number-animate;
      animation-duration: 18s;
      animation-iteration-count: infinite;
      /* Synchronized with forward card carousel timing */
    }

    @keyframes number-animate {
      0%,
      16.665% {
        content: "01";
      }
      16.666%,
      33.332% {
        content: "02";
      }
      33.333%,
      49.999% {
        content: "03";
      }
      50%,
      66.665% {
        content: "04";
      }
      66.666%,
      83.332% {
        content: "05";
      }
      83.333%,
      100% {
        content: "06";
      }
    }

    .process-card {
      min-height: 140px; /* Ensure consistent height for precise flex timeline alignment */
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initHowWeWorkAnimation() {
    const section = document.querySelector(".how-we-work");
    if (!section) return;

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (prefersReducedMotion) return;

    gsap.set(".how-we-work__headline .headline-line", { clearProps: "all" });

    gsap.from(".how-we-work__headline .headline-line", {
      scrollTrigger: {
        trigger: section,
        start: "top 75%",
      },
      y: "100%",
      opacity: 0,
      duration: 1.0,
      stagger: 0.15,
      ease: "power3.out",
      clearProps: "all",
    });
  }

  document.addEventListener("DOMContentLoaded", initHowWeWorkAnimation);
  document.addEventListener("astro:page-load", initHowWeWorkAnimation);
</script>
