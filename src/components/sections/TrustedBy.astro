---
import client01 from '../../images/Clients/Client_01.png';
import client02 from '../../images/Clients/Client_02.png';
import client03 from '../../images/Clients/Client_03.png';
import client04 from '../../images/Clients/Client_04.png';
import client05 from '../../images/Clients/Client_05.png';
import client06 from '../../images/Clients/Client_06.png';
import client07 from '../../images/Clients/Client_07.png';
import client08 from '../../images/Clients/Client_08.png';
import client09 from '../../images/Clients/Client_09.png';
import client10 from '../../images/Clients/Client_10.png';
import client11 from '../../images/Clients/Client_11.png';
import client12 from '../../images/Clients/Client_12.png';
import client13 from '../../images/Clients/Client_13.png';
import client14 from '../../images/Clients/Client_14.png';
import client15 from '../../images/Clients/Client_15.png';
import client16 from '../../images/Clients/Client_16.png';
import client17 from '../../images/Clients/Client_17.png';
import client18 from '../../images/Clients/Client_18.png';
import client19 from '../../images/Clients/Client_19.png';
import client20 from '../../images/Clients/Client_20.png';
import client21 from '../../images/Clients/Client_21.png';
import client22 from '../../images/Clients/Client_22.png';
import client23 from '../../images/Clients/Client_23.png';
import client24 from '../../images/Clients/Client_24.png';
import client25 from '../../images/Clients/Client_25.png';
import client26 from '../../images/Clients/Client_26.png';
import client27 from '../../images/Clients/Client_27.png';
import client28 from '../../images/Clients/Client_28.png';
import client29 from '../../images/Clients/Client_29.png';
import client30 from '../../images/Clients/Client_30.png';
import client31 from '../../images/Clients/Client_31.png';
import client32 from '../../images/Clients/Client_32.png';
import client33 from '../../images/Clients/Client_33.png';
import client34 from '../../images/Clients/Client_34.png';
import client35 from '../../images/Clients/Client_35.png';

// Row 1: 18 logos
const row1 = [
  client01, client02, client03, client04, client05, client06, client07, client08, client09,
  client10, client11, client12, client13, client14, client15, client16, client17, client18
];

// Row 2: 17 logos
const row2 = [
  client19, client20, client21, client22, client23, client24, client25, client26, client27,
  client28, client29, client30, client31, client32, client33, client34, client35
];
---

<section class="trusted-by">
  <div class="container trusted-container">
    <div class="trusted-pill-wrapper">
      <span class="label-pill">Trusted Across Enterprise & Government Sectors</span>
    </div>
  </div>
  
  <div class="marquee-wrapper">
      <!-- Row 1 of logos (moves right) -->
      <div class="logo-row logo-row-right">
        <div class="logo-track">
          <div class="logo-set">
            {row1.map((logo) => (
              <img 
                src={logo.src} 
                width={logo.width === 234 ? 117 : 84} 
                height={84} 
                loading="eager" 
                decoding="async" 
                alt="Client Logo" 
                class="client-logo-img" 
              />
            ))}
          </div>
          <div class="logo-set">
            {row1.map((logo) => (
              <img 
                src={logo.src} 
                width={logo.width === 234 ? 117 : 84} 
                height={84} 
                loading="eager" 
                decoding="async" 
                alt="Client Logo" 
                class="client-logo-img" 
              />
            ))}
          </div>
        </div>
      </div>
      <!-- Row 2 of logos (moves left) -->
      <div class="logo-row logo-row-left">
        <div class="logo-track">
          <div class="logo-set">
            {row2.map((logo) => (
              <img 
                src={logo.src} 
                width={logo.width === 234 ? 117 : 84} 
                height={84} 
                loading="eager" 
                decoding="async" 
                alt="Client Logo" 
                class="client-logo-img" 
              />
            ))}
          </div>
          <div class="logo-set">
            {row2.map((logo) => (
              <img 
                src={logo.src} 
                width={logo.width === 234 ? 117 : 84} 
                height={84} 
                loading="eager" 
                decoding="async" 
                alt="Client Logo" 
                class="client-logo-img" 
              />
            ))}
          </div>
        </div>
      </div>
    </div>
</section>

<style>
  .trusted-by {
    background-color: var(--color-white);
    padding-top: var(--space-4);
    padding-bottom: var(--space-4);
    overflow: hidden; /* Prevent horizontal scrollbars on the main document */
    width: 100%;
  }

  .trusted-container {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .trusted-pill-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: 24px; /* Space (24px) */
    width: 100%;
  }

  .marquee-wrapper {
    display: flex;
    flex-direction: column;
    gap: 16px; /* gap between row 16px */
    margin-bottom: 32px; /* Space (32px) */
    width: 100%;
    overflow: hidden;
    perspective: 1000px;
    -webkit-perspective: 1000px;
  }

  .logo-row {
    display: block;
    overflow: hidden;
    width: 100%;
  }

  .logo-track {
    display: flex;
    width: max-content;
    flex-shrink: 0;
    will-change: transform;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    transform: translate3d(0, 0, 0);
  }

  .logo-set {
    display: flex;
    align-items: center;
    gap: 16px; /* space between client logos 16px */
    padding-right: 16px; /* matching padding at the end of the set to maintain consistent spacing between sets */
    flex-shrink: 0;
  }

  /* Moving Left (Row 2) - Faster speed */
  .logo-row-left .logo-track {
    animation: marquee-left 30s linear infinite;
  }

  /* Moving Right (Row 1) - Slower speed */
  .logo-row-right .logo-track {
    animation: marquee-right 40s linear infinite;
  }

  @keyframes marquee-left {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      transform: translate3d(-50%, 0, 0);
    }
  }

  @keyframes marquee-right {
    0% {
      transform: translate3d(-50%, 0, 0);
    }
    100% {
      transform: translate3d(0, 0, 0);
    }
  }

  .client-logo-img {
    height: 84px; /* Height set to 84px to guarantee integer widths (117px & 84px) for all logos, eliminating subpixel layout jitter */
    width: auto;
    object-fit: contain;
    flex-shrink: 0;
    will-change: transform;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    transform: translate3d(0, 0, 0);
  }

  /* Reset animations if user prefers reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .logo-row-left .logo-track,
    .logo-row-right .logo-track {
      animation: none;
      transform: none;
    }
    .logo-row {
      justify-content: center;
    }
    .logo-track {
      width: 100%;
      justify-content: center;
      flex-wrap: wrap;
      gap: 16px;
    }
    .logo-set {
      padding-right: 0;
      gap: 16px;
      flex-wrap: wrap;
      justify-content: center;
    }
    .logo-set:nth-child(2) {
      display: none;
    }
  }
</style>
