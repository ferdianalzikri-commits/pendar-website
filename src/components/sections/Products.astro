---
import imgProcura from "../../images/image-procura.png";
import imgCatalogue from "../../images/image-catalogue.png";
import imgMarketplace from "../../images/image-marketplace.png";
import imgCabinBag from "../../images/image-cabin-bag.png";
import imgPms from "../../images/image-pms.png";
import imgTravel from "../../images/image-travel.png";
import imgLenient from "../../images/image-lenient.png";
import imgCustom from "../../images/image-custom.png";

const products = [
  {
    id: "procura",
    name: "Procura",
    description: "An electronic procurement system that streamlines company purchasing with fast, efficient, and transparent workflows.",
    image: imgProcura,
    modules: ["Vendor Management", "e-Auction", "Tender Management", "Purchase Orders", "Contract Monitoring", "Supply Chain"],
    devices: ["Mobile", "Web"],
    linkText: "Visit Procura",
    linkHref: "https://www.procura.id"
  },
  {
    id: "catalogue",
    name: "Electronic Catalogue",
    description: "An e-catalogue that lists verified goods and services with specs, prices, and availability making procurement fast and transparent.",
    image: imgCatalogue,
    modules: ["Vendor Catalogue", "Purchase Order", "Negotiation", "Direct Messaging"],
    devices: ["Mobile", "Web"],
    linkText: "Visit Procura",
    linkHref: "https://www.procura.id"
  },
  {
    id: "marketplace",
    name: "Marketplace",
    description: "Dual marketplace platforms for property browsing and motorcycle workshop services, with booking, tracking, and purchase flows.",
    image: imgMarketplace,
    modules: ["Property Listings", "Workshop Booking", "Tracker Route", "Sales Dashboard"],
    devices: ["Mobile", "Web"],
    linkText: "",
    linkHref: "#contact"
  },
  {
    id: "electronic-cabin-bag",
    name: "Electronic Cabin Bag",
    description: "An electronic cabin system that helps crew manage passenger seating, meals, and in-flight inventory seamlessly.",
    image: imgCabinBag,
    modules: ["Pax Manifest", "Seat Option", "Stock Take", "Inflight Sales", "Passenger List"],
    devices: ["Desktop App"],
    linkText: "",
    linkHref: "#contact"
  },
  {
    id: "port-management-system",
    name: "Port Management System",
    description: "A port management system that streamlines cruise operations, coordinating berths, passengers, and vessel services efficiently.",
    image: imgPms,
    modules: ["Vessel Booking", "Passenger Check-In", "Baggage Check-In", "Voyage Report", "Port Dashboard"],
    devices: ["Web"],
    linkText: "",
    linkHref: "#contact"
  },
  {
    id: "traveling-platform",
    name: "Traveling Platform",
    description: "Ship and flight booking platforms helping users access schedules, compare fares, and manage travel services on the go.",
    image: imgTravel,
    modules: ["Transport Booking", "Seat Selection", "Tour Packages", "Baggage Management", "Payment Methods"],
    devices: ["Web", "Mobile"],
    linkText: "",
    linkHref: "#contact"
  },
  {
    id: "lenient-hr-system",
    name: "Lenient HR System",
    description: "A human resource system that enhances workforce management through automated workflows and unified employee data.",
    image: imgLenient,
    modules: ["Attendance", "Payroll", "Compliance", "Performance", "Talent Management", "Training"],
    devices: ["Web", "Mobile"],
    linkText: "",
    linkHref: "#contact"
  },
  {
    id: "custom-systems",
    name: "Custom System & Workflow",
    description: "Solutions designed around your organization's unique workflows, operational requirements, and integration needs.",
    image: imgCustom,
    modules: ["Workflow Analysis", "System Integration", "Custom Development", "Automation", "API Integration", "Scalability"],
    devices: ["Web", "Desktop", "Mobile"],
    linkText: "Contact Us",
    linkHref: "#contact"
  }
];

const slides = [
  products.slice(0, 3),
  products.slice(3, 6),
  products.slice(6, 8)
];
---

<section class="products" id="products">
  <div class="products__pin-wrapper">
    <div class="container">
      <!-- Header aligned side-by-side on desktop, persistent to AboutIndustries layout -->
      <div class="products__header">
        <div class="products__title">
          <h2 class="products__headline">
            <span class="headline-mask"><span class="headline-line">Built for Operations.<br class="desktop-only" /></span></span>
            <span class="headline-mask"><span class="headline-line">Tailored for Your<br class="desktop-only" /></span></span>
            <span class="headline-mask"><span class="headline-line">Business.</span></span>
          </h2>
        </div>
        <div class="products__content">
          <p class="products__description">
            <strong>7 enterprise solutions</strong> across procurement, workforce management, logistics, aviation, and infrastructure <strong>or work with us to design solutions that align with your organization's</strong> unique workflows and operational goals.
          </p>
        </div>
      </div>

      <!-- Container wrapper for cards & vertical dots scroll indicator -->
      <div class="products__container-wrapper">
        <!-- Scroll indicator track & text -->
        <div class="products__scroll-indicator">
          <div class="scroll-track">
            <div class="scroll-thumb"></div>
          </div>
          <span class="scroll-text">Scroll Up or Down to Explore</span>
        </div>

        <!-- Cards List Viewport -->
        <div class="products__list-viewport">
          <div class="products__track">
            {products.map((product, index) => (
              <div class="product-card-wrapper" id={`${product.id}-wrapper`} data-index={index}>
                <div class="product-card-glow"></div>
                <div class="product-card" id={product.id}>
                  <!-- Image height 224px, 60% (134px) extends outside, 40% (90px) inside -->
                  <img src={product.image.src} alt={product.name} class="product-card__image" width={product.image.width} height={product.image.height} loading="lazy" decoding="async" />
                  
                  <!-- Card title (text-lg, 700, blue, left-aligned) -->
                  <h3 class="product-card__title">{product.name}</h3>
                  
                  <!-- Card description (text-base, 500, blue, left-aligned) -->
                  <p class="product-card__desc">{product.description}</p>
                  
                  <!-- Modules (Pills, text-xs, 500, blue, horizontal & vertical wrap, space-2 gap) -->
                  <div class="product-card__modules">
                    {product.modules.map((mod) => (
                      <span class="product-card__mod-pill">{mod}</span>
                    ))}
                  </div>
                  
                  <!-- Footer Row containing Devices (left) & Link (right) -->
                  <div class="product-card__footer">
                    <div class="product-card__devices">
                      {product.devices.map((device) => (
                        <span class="product-card__device-pill">{device}</span>
                      ))}
                    </div>
                    
                    {product.linkText && (
                      <a 
                        href={product.linkHref} 
                        class="product-card__link"
                        target={product.linkHref.startsWith('http') ? '_blank' : undefined}
                        rel={product.linkHref.startsWith('http') ? 'noopener noreferrer' : undefined}
                      >
                        {product.linkText}
                        <svg class="product-card__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                          <line x1="7" y1="17" x2="17" y2="7"></line>
                          <polyline points="7 7 17 7 17 17"></polyline>
                        </svg>
                      </a>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .products {
    margin-top: var(--space-10); /* Space-40 (40px) below previous section */
    position: relative;
    overflow: visible;
  }

  .products__pin-wrapper {
    width: 100%;
    position: relative;
    padding-top: 80px;
    padding-bottom: 80px;
  }

  .products__header {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4); /* space-16 (16px) gap from headline on mobile */
    align-items: center;
    text-align: center;
    margin-bottom: var(--space-16); /* space-16 spacing below header to card list */
  }

  .products__title {
    max-width: 100%;
  }

  .products__headline {
    font-size: var(--text-xl); /* Matches AboutIndustries mobile sizing */
    font-weight: 600;
    color: var(--color-white);
    line-height: 1.15;
    margin: 0;
    text-align: center;
  }

  /* Specificity Boost to override global dark-sections-wrapper rules */
  section.products p.products__description {
    font-size: var(--text-base); /* text-base on mobile */
    font-weight: 500;
    color: var(--color-light-blue) !important;
    line-height: 1.6;
    margin: 0;
    text-align: center;
  }

  section.products p.products__description strong {
    color: var(--color-light-blue) !important;
    font-weight: 700;
  }

  .products__container-wrapper {
    position: relative;
    width: 100%;
  }

  .products__scroll-indicator {
    display: none; /* Hidden on mobile/tablet */
  }

  .products__list-viewport {
    position: relative;
    width: 100%;
    margin-top: 198.4px; /* Push list down to prevent margin collapse with header & spacing */
    overflow-x: clip;
  }

  .products__track {
    display: flex;
    flex-wrap: nowrap;
    gap: var(--space-6);
    width: max-content;
    padding-left: 0;
    padding-right: 0;
  }

  .product-card-wrapper {
    position: relative;
    display: grid;
    width: var(--container-width, 100%); /* Mobile: 1 card takes full width */
  }

  @media (min-width: 768px) {
    .product-card-wrapper {
      width: calc((var(--container-width, 100%) - var(--space-6)) / 2); /* Tablet: 2 cards */
    }
  }

  .product-card-glow {
    position: absolute;
    bottom: -30px;
    left: 50%;
    transform: translate3d(-50%, 0, 0);
    will-change: transform;
    width: 260px;
    height: 120px;
    background-color: var(--color-med-blue);
    border-radius: 50%;
    filter: blur(50px);
    opacity: 0.65;
    z-index: 1;
    pointer-events: none;
    backface-visibility: hidden;
  }

  /* Premium Card Design */
  .product-card {
    background-color: var(--color-shade-blue);
    border-radius: 48px; /* 48px rounded corners */
    padding: 106px 32px 32px 32px; /* 32px side & bottom padding; top padding is 106px (89.6px image + 16.4px space-4) */
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 2; /* Sits above the glow */
    flex-grow: 1;
  }

  .product-card__image {
    height: 224px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    position: absolute;
    top: -134.4px; /* 60% outside the card */
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }

  section.products div.product-card h3.product-card__title {
    font-size: var(--text-lg); /* text-lg */
    font-weight: 700;
    color: var(--color-blue) !important;
    text-align: left;
    margin: 0;
    line-height: 1.35;
  }

  section.products div.product-card p.product-card__desc {
    font-size: var(--text-base); /* text-base */
    font-weight: 500;
    color: var(--color-blue) !important;
    text-align: left;
    margin: 0;
    margin-top: var(--space-6); /* space-6 (24px) */
    line-height: 1.6;
  }

  .product-card__modules {
    display: flex;
    flex-wrap: wrap;
    align-content: flex-start;
    align-items: flex-start;
    gap: var(--space-2); /* space-2 (8px) gap between pills */
    margin-top: var(--space-6); /* space-6 (24px) */
  }

  section.products div.product-card span.product-card__mod-pill {
    font-size: var(--text-xs); /* text-xs */
    font-weight: 500;
    color: var(--color-blue) !important;
    background-color: var(--color-white) !important;
    border: none !important; /* Remove border completely */
    padding: 6px 12px; /* py:6px, px:12px */
    border-radius: var(--radius-full);
    display: inline-block;
  }

  .product-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: var(--space-6); /* space-6 (24px) */
    width: 100%;
  }

  .product-card__devices {
    display: flex;
    gap: var(--space-2); /* space-2 (8px) gap between pills */
  }

  section.products div.product-card span.product-card__device-pill {
    font-size: var(--text-xs); /* text-xs */
    font-weight: 500;
    color: var(--color-orange) !important;
    background-color: rgba(242, 99, 13, 0.25) !important; /* orange 25% opacity */
    border: 1.5px solid var(--color-orange) !important; /* 1.5px orange stroke */
    padding: 6px 12px; /* py:6px, px:12px */
    border-radius: var(--radius-full);
    display: inline-block;
  }

  section.products div.product-card a.product-card__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2); /* space-2 (8px) between text and icon */
    color: var(--color-blue) !important;
    font-size: var(--text-xs);
    font-weight: 500;
    text-decoration: none;
    padding: 6px 12px; /* Same pill composition */
    border: 1.5px solid var(--color-blue) !important; /* 1.5px blue border stroke */
    background-color: transparent !important;
    border-radius: var(--radius-full);
    transition: var(--transition-all);
  }

  section.products div.product-card a.product-card__link:hover {
    color: var(--color-orange) !important;
    border-color: var(--color-orange) !important;
  }

  .product-card__link-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  @media (min-width: 1024px) {
    .products__header {
      grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
      gap: var(--space-24); /* Persistent structure with AboutIndustries but space-24 gap */
      align-items: start;
      text-align: left;
    }

    .products__content {
      max-width: 720px; /* Persistent with AboutIndustries */
    }

    .products__headline {
      font-size: var(--text-2xl); /* Matches AboutIndustries.astro desktop headline */
      text-align: left;
    }

    section.products p.products__description {
      font-size: var(--text-md);
      text-align: left;
    }

    .desktop-only {
      display: inline;
    }

    .products__container-wrapper {
      margin-bottom: var(--space-16); /* Reserve space for the absolute bottom indicator */
    }

    .products__scroll-indicator {
      display: flex;
      flex-direction: row; /* Make horizontal */
      justify-content: center;
      gap: var(--space-4); /* Horizontal gap */
      flex-shrink: 0;
      position: absolute;
      left: 50%;
      bottom: calc(-1 * var(--space-24));
      transform: translateX(-50%);
      z-index: 10;
    }

    .scroll-track {
      width: 72px;
      height: 20px;
      border-radius: 999px;
      border: 1.5px solid var(--color-light-blue);
      display: flex;
      align-items: center;
      padding: 2.5px;
      box-sizing: border-box;
      position: relative;
    }

    .scroll-thumb {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background-color: var(--color-orange);
      flex-shrink: 0;
      position: absolute;
      left: 2.5px;
      will-change: transform;
    }

    .scroll-text {
      font-size: var(--text-xs);
      font-weight: 600;
      color: var(--color-white);
      white-space: nowrap;
    }

    .products__list-viewport {
      margin-top: 198.4px;
    }

    .products__track {
      gap: var(--space-8);
    }

    .product-card-wrapper {
      width: calc((var(--container-width, 100%) - (var(--space-8) * 2)) / 3); /* Desktop: 3 cards */
    }

    #custom-systems-wrapper {
      /* Custom System card spans 2 columns width */
      width: calc((((var(--container-width, 100%) - (var(--space-8) * 2)) / 3) * 2) + var(--space-8));
    }
  }

  /* Custom Systems (Card 8) Overrides */
  section.products div#custom-systems {
    background-color: var(--color-light-blue) !important;
    border: 2px solid var(--color-shade-blue) !important;
  }

  section.products div#custom-systems span.product-card__mod-pill {
    background-color: var(--color-shade-blue) !important;
  }

  section.products div#custom-systems span.product-card__device-pill {
    color: var(--color-blue) !important;
    border-color: var(--color-blue) !important;
    background-color: color-mix(in srgb, var(--color-med-blue) 50%, transparent) !important;
  }

  section.products div#custom-systems a.product-card__link {
    background-color: var(--color-orange) !important;
    border-color: transparent !important;
    color: var(--color-white) !important;
  }

  section.products div#custom-systems a.product-card__link:hover {
    background-color: transparent !important;
    border-color: var(--color-orange) !important;
    color: var(--color-orange) !important;
  }

  @media (max-width: 1023px) {
    .desktop-only {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .product-card {
      border-radius: 32px;
    }
  }

  /* Very small mobile screens */
  @media (max-width: 400px) {
    .products__pin-wrapper {
      padding-top: 48px;
      padding-bottom: 48px;
    }

    .products__headline {
      font-size: 1.5rem;
    }

    .products__list-viewport {
      margin-top: 140px;
    }

    .product-card {
      border-radius: 24px;
      padding: 80px 20px 20px 20px;
    }

    .product-card__image {
      height: 160px;
      top: -96px;
    }

    section.products div.product-card h3.product-card__title {
      font-size: var(--text-base);
    }

    section.products div.product-card p.product-card__desc {
      font-size: var(--text-xs);
      margin-top: var(--space-4);
    }

    .product-card__modules {
      margin-top: var(--space-4);
    }

    section.products div.product-card span.product-card__mod-pill {
      font-size: 0.75rem;
      padding: 4px 10px;
    }

    section.products div.product-card span.product-card__device-pill {
      font-size: 0.75rem;
      padding: 4px 10px;
    }

    section.products div.product-card a.product-card__link {
      font-size: 0.75rem;
      padding: 4px 10px;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let mm: gsap.MatchMedia;

  function initProductsAnimation() {
    if (mm) {
      mm.revert();
    }

    const section = document.querySelector(".products") as HTMLElement;
    if (!section) return;

    // Check prefers-reduced-motion
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (prefersReducedMotion) return;

    mm = gsap.matchMedia();

    // Universal Responsive Horizontal Slider
    mm.add("all", () => {
      const track = section.querySelector(".products__track") as HTMLElement;
      const cards = Array.from(section.querySelectorAll(".product-card"));
      const dots = section.querySelectorAll(".products__scroll-indicator .scroll-dot");

      if (!track || cards.length === 0) return;
      
      const wrapper = section.querySelector(".products__list-viewport") as HTMLElement;
      const containerWrapper = section.querySelector(".products__container-wrapper") as HTMLElement;
      
      // Calculate dynamic container measurements
      const calculateBounds = () => {
        // Reset styles to measure original DOM state accurately on resize
        wrapper.style.width = "";
        wrapper.style.marginLeft = "";
        track.style.paddingLeft = "";
        track.style.paddingRight = "";

        const layoutMargin = containerWrapper.getBoundingClientRect().left;
        const containerWidth = containerWrapper.clientWidth;

        section.style.setProperty("--layout-margin", `${layoutMargin}px`);
        section.style.setProperty("--container-width", `${containerWidth}px`);

        // Dynamically create full-bleed effect without 100vw CSS bugs
        wrapper.style.width = `${window.innerWidth}px`;
        wrapper.style.marginLeft = `-${layoutMargin}px`;
        
        // Pad the track so cards start and stop perfectly within layout margins
        track.style.paddingLeft = `${layoutMargin}px`;
        track.style.paddingRight = `${layoutMargin}px`;
      };
      
      calculateBounds();
      
      // Absolute Robust Height Matching
      const matchHeights = () => {
        const descs = section.querySelectorAll(".product-card__desc");
        const modules = section.querySelectorAll(".product-card__modules");
        
        let maxCard = 0, maxDesc = 0, maxMod = 0;
        
        // Reset all
        cards.forEach(c => (c as HTMLElement).style.minHeight = '0');
        descs.forEach(d => (d as HTMLElement).style.minHeight = '0');
        modules.forEach(m => (m as HTMLElement).style.minHeight = '0');
        
        // Calculate max heights for inner content
        descs.forEach(d => { const h = (d as HTMLElement).offsetHeight; if (h > maxDesc) maxDesc = h; });
        modules.forEach(m => { const h = (m as HTMLElement).offsetHeight; if (h > maxMod) maxMod = h; });
        
        // Apply inner max heights
        descs.forEach(d => (d as HTMLElement).style.minHeight = `${maxDesc}px`);
        modules.forEach(m => (m as HTMLElement).style.minHeight = `${maxMod}px`);
        
        // Calculate and apply max height for the whole card
        cards.forEach(c => { const h = (c as HTMLElement).offsetHeight; if (h > maxCard) maxCard = h; });
        cards.forEach(c => (c as HTMLElement).style.minHeight = `${maxCard}px`);
        
        ScrollTrigger.refresh();
      };
      
      const resizeObserver = new ResizeObserver(() => {
        calculateBounds();
        matchHeights();
      });
      resizeObserver.observe(track);
      // Observe the viewport to detect layout changes
      resizeObserver.observe(wrapper);
      
      // Entrance animation
      const tlEntrance = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: "top 75%",
        }
      });

      tlEntrance.from(".products__headline .headline-line", {
        y: "100%", opacity: 0, duration: 1.0, stagger: 0.15, ease: "power3.out", clearProps: "all"
      })
      .from(".products__description", {
        y: 30, opacity: 0, duration: 1.0, ease: "power3.out", clearProps: "all"
      }, "-=0.6")
      .from(cards.slice(0, 3), { // Animate first few cards on entrance
        y: 80, opacity: 0, duration: 1.2, stagger: 0.15, ease: "power3.out", clearProps: "all"
      }, "-=0.6");

      // Calculate horizontal scroll distance
      const scrollDistance = () => {
        // With the full-bleed wrapper, wrapper.clientWidth is window.innerWidth.
        // The track has padding-right equal to the layoutMargin.
        // Translating exactly -(track.scrollWidth - wrapper.clientWidth) makes the track's right edge touch the screen edge.
        // Because of the padding-right, the last card is pushed back by exactly the layoutMargin,
        // making it stop precisely at the container right edge (matching the Navbar Contact button).
        return -(track.scrollWidth - wrapper.clientWidth); 
      };

      // Pinning Scroll Slider (Dynamic Horizontal Scrub)
      const tlSlider = gsap.timeline({
        scrollTrigger: {
          trigger: ".products__track",
          start: "center-=67.2px center", // Shift start by exactly half the image offset to find true visual center
          end: () => "+=" + track.scrollWidth, // Map scroll distance exactly to track width
          pin: ".products__pin-wrapper",
          scrub: 1, // Smooth dampening
          invalidateOnRefresh: true, // Recalculate widths on resize
        }
      });

      // Linear horizontal movement
      tlSlider.to(track, { 
        x: scrollDistance, 
        ease: "none" 
      }, 0);
      
      // Animate the thumb simultaneously
      tlSlider.to(".scroll-thumb", {
        x: 52, // 52px travel distance (72px track - 12px thumb - padding)
        ease: "none"
      }, 0);
    });
  }

  document.addEventListener("DOMContentLoaded", initProductsAnimation);
  document.addEventListener("astro:page-load", initProductsAnimation);
</script>
