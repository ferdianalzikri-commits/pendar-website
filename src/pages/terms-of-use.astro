---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout 
  title="Terms of Use | PT Pendar Sinergi Utama" 
  description="Terms governing the use of the Pendar website and related information provided by PT Pendar Sinergi Utama."
>
  <div class="legal-page section-padding">
    <div class="legal-container">

      
      <header class="legal-header">
        <span class="label-pill">Legal</span>
        <h1>Terms of Use</h1>
        <p class="subtitle">
          These terms govern the use of the Pendar website and related information provided by <strong class="company-name">PT Pendar Sinergi Utama</strong>.
        </p>
      </header>

      <div class="legal-content">
        <article>
          <section>
            <h2>Acceptance of Terms</h2>
            <p>By accessing this website, users agree to these Terms of Use and all applicable laws and regulations.</p>
          </section>

          <section>
            <h2>Website Content</h2>
            <p>All content, trademarks, logos, graphics, and materials displayed on this website belong to <strong class="company-name">PT Pendar Sinergi Utama</strong> unless otherwise stated. Unauthorized reproduction or distribution is prohibited.</p>
          </section>

          <section>
            <h2>Information Disclaimer</h2>
            <p>Information provided on this website is intended for general informational purposes and may be updated without prior notice.</p>
          </section>

          <section>
            <h2>External Links</h2>
            <p>This website may contain links to third-party websites. <strong class="company-name">PT Pendar Sinergi Utama</strong> is not responsible for the content or privacy practices of those websites.</p>
          </section>

          <section>
            <h2>Limitation of Liability</h2>
            <p><strong class="company-name">PT Pendar Sinergi Utama</strong> shall not be liable for any direct or indirect damages arising from the use of this website.</p>
          </section>

          <section>
            <h2>Changes to Terms</h2>
            <p>These Terms of Use may be updated periodically. Continued use of the website constitutes acceptance of any revisions.</p>
          </section>

          <section>
            <h2>Contact Information</h2>
            <p>
              <strong class="company-name">PT Pendar Sinergi Utama</strong><br />
              Email: <a href="mailto:info@procura.id">info@procura.id</a>
            </p>
          </section>
        </article>
      </div>

      <div class="back-nav">
        <a href="/" class="btn-back">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          Back to Home
        </a>
      </div>
    </div>
  </div>
</MainLayout>

<style>
  .legal-page {
    background-color: var(--color-bg);
    min-height: 100vh;
  }

  .legal-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 var(--space-4);
    position: relative;
  }

  .back-nav {
    margin-top: var(--space-24);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: flex-start;
  }

  .btn-back {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 500;
    color: var(--color-blue);
    text-decoration: none;
    background: var(--color-shade-blue);
    padding: 8px 16px;
    border-radius: var(--radius-full);
    transition: var(--transition-all);
  }

  .btn-back:hover {
    background: var(--color-blue);
    color: var(--color-white);
  }

  .legal-header {
    margin-bottom: var(--space-16);
  }

  .legal-header h1 {
    font-size: var(--text-3xl);
    margin-top: var(--space-4);
    margin-bottom: var(--space-6);
    letter-spacing: -0.02em;
  }

  .legal-header .subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 600px;
  }

  .legal-content article {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .legal-content section {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-12);
  }

  .legal-content section:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .legal-content h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
    color: var(--color-navy);
  }

  .legal-content p, 
  .legal-content ul {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  .legal-content ul {
    list-style-type: disc;
    margin-top: var(--space-4);
    padding-left: var(--space-6);
  }

  .legal-content li {
    margin-bottom: var(--space-2);
  }

  .legal-content a {
    color: var(--color-orange);
    text-decoration: underline;
    font-weight: 500;
  }

  .legal-content a:hover {
    text-decoration: none;
  }

  .company-name {
    font-weight: 700;
    white-space: nowrap !important;
    display: inline-block;
  }
</style>
